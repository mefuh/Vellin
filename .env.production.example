# Generate with: openssl rand -hex 32
JWT_SECRET=__GENERATE_ME_WITH_openssl_rand_-hex_32__

# Generate with: openssl rand -base64 24
DB_PASSWORD=__GENERATE_ME_WITH_openssl_rand_-base64_24__
