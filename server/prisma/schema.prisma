generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  username     String    @unique
  passwordHash String
  avatarSeed   String
  /// Путь к загруженному аватару (/api/uploads/avatars/...). Null — рисуем
  /// градиент по avatarSeed.
  avatarUrl    String?
  /// Произвольный текст «О себе».
  bio          String?
  /// Пол: 'male' | 'female' | 'other'. Null — не указан.
  gender       String?
  /// Дата рождения (хранится как UTC-полночь, в API — строка YYYY-MM-DD).
  birthDate    DateTime?
  /// Город. Null — не указан.
  city         String?
  createdAt    DateTime  @default(now())
  /// Момент последнего ухода в офлайн (для «был в сети …»). Null — ещё не уходил.
  lastSeenAt   DateTime?
  /// JSON настроек приватности (PrivacySettings). Пусто/невалидно → всё видно
  /// всем (текущее поведение). Категории: online, friends, personalInfo, favorites.
  privacyJson  String    @default("{}")

  isBlocked    Boolean   @default(false)
  blockedAt    DateTime?
  blockReason  String?

  rooms        Room[]       @relation("RoomOwner")
  messages     Message[]
  memberships  Membership[]
  sessions     Session[]

  friendRequestsSent     Friendship[]   @relation("FriendRequester")
  friendRequestsReceived Friendship[]   @relation("FriendAddressee")
  blocksMade             Block[]        @relation("Blocker")
  blockedBy              Block[]        @relation("Blocked")
  notifications          Notification[]
  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  favoriteTitles         FavoriteTitle[]
  conversationsA         Conversation[]  @relation("ConvUserA")
  conversationsB         Conversation[]  @relation("ConvUserB")
  directMessages         DirectMessage[] @relation("DmSender")

  @@index([isBlocked])
}

/// До 5 любимых фильмов/сериалов пользователя (профиль). Снимок данных из
/// kinopoisk.dev на момент выбора — чтобы профиль рисовался из своей БД без
/// обращений к внешнему API. position 0..4 задаёт порядок (#1..#5).
model FavoriteTitle {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  position      Int // 0..4
  kpId          Int // id фильма в Кинопоиске
  type          String // 'movie' | 'tv-series' | 'cartoon' | 'anime' | ...
  title         String
  originalTitle String?
  year          Int?
  posterUrl     String?
  ratingKp      Float?
  ratingImdb    Float?
  createdAt     DateTime @default(now())

  @@unique([userId, position])
  @@index([userId])
}

/// Дружба/заявка между двумя пользователями. Одна строка на пару (в одном
/// направлении requester→addressee). status: 'pending' | 'accepted'.
model Friendship {
  id          String    @id @default(cuid())
  requesterId String
  addresseeId String
  requester   User      @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User      @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      String // 'pending' | 'accepted'
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

/// Блокировка пользователя. Блок удаляет дружбу/заявки и запрещает новые.
model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

/// Личное уведомление пользователя (колокольчик). Расширяемо по type.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // 'friend_request' | 'friend_accepted' | 'room_invite'
  actorId   String? // кто инициировал
  dataJson  String    @default("{}") // {roomSlug, roomName, friendshipId, ...}
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
}

/// Web-Push подписка одного устройства/браузера пользователя. endpoint —
/// уникальный URL push-сервиса; p256dh/auth — ключи шифрования полезной
/// нагрузки. Недействительные (404/410 от push-сервиса) деактивируются.
model PushSubscription {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint     String   @unique
  p256dh       String
  auth         String
  browser      String   @default("")
  os           String   @default("")
  deviceLabel  String   @default("")
  userAgent    String?
  active       Boolean  @default(true)
  failureCount Int      @default(0)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())

  @@index([userId])
  @@index([active])
}

/// Настройки уведомлений пользователя. pushEnabled — главный выключатель;
/// categoriesJson — карта категория→bool (отсутствие ключа = включено), что
/// позволяет добавлять новые категории без миграций.
model NotificationPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled    Boolean  @default(true)
  categoriesJson String   @default("{}")
  updatedAt      DateTime @updatedAt
}

/// Редактируемый из админки шаблон push-уведомления по типу. Поля title/body/url
/// поддерживают переменные вида {{username}}, {{roomName}}, {{message}}, {{movie}}.
model NotificationTemplate {
  id                 String   @id @default(cuid())
  type               String   @unique // PushNotificationType
  title              String
  body               String
  icon               String   @default("/icon-192.png")
  badge              String   @default("/badge-72.png")
  image              String?
  url                String   @default("/")
  sound              String?
  ttl                Int      @default(86400)
  urgency            String   @default("normal") // very-low | low | normal | high
  requireInteraction Boolean  @default(false)
  tag                String?
  silent             Boolean  @default(false)
  enabled            Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  updatedBy          String?
}

/// Очередь push-отправки. Одна запись = доставка одного payload на ОДНУ
/// подписку (per-device) — так ретраи чисты и без дублей. Воркер забирает
/// батч `FOR UPDATE SKIP LOCKED`, отправляет, при временной ошибке переносит
/// `nextAttemptAt` с экспоненциальным бэкоффом, при исчерпании попыток → dead.
model PushJob {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String
  type           String // PushNotificationType
  payloadJson    String
  status         String   @default("pending") // pending | sending | sent | failed | dead
  attempts       Int      @default(0)
  maxAttempts    Int      @default(5)
  nextAttemptAt  DateTime @default(now())
  /// Ключ дедупликации/коалесинга — повторный enqueue с тем же ключом обновляет
  /// pending-джоб, а не плодит новый (защита от спама/дублей).
  dedupeKey      String?
  createdAt      DateTime @default(now())
  sentAt         DateTime?
  lastError      String?

  @@index([status, nextAttemptAt])
  @@index([dedupeKey])
  @@index([userId])
}

/// Журнал доставок push (для статистики/аналитики). Одна запись на попытку
/// отправки на конкретную подписку с финальным статусом и причиной.
model PushDelivery {
  id             String    @id @default(cuid())
  jobId          String?
  userId         String
  subscriptionId String?
  type           String
  status         String // sent | failed | expired | rejected | clicked
  error          String?
  browser        String?
  os             String?
  sentAt         DateTime  @default(now())
  clickedAt      DateTime?

  @@index([type, sentAt])
  @@index([userId])
  @@index([status, sentAt])
}

/// История массовых push-рассылок из админки (для аналитики/аудита). audienceJson
/// хранит описание аудитории (all | role | userIds), totalTargets/sent/failed —
/// итоги постановки в очередь.
model PushBroadcast {
  id           String   @id @default(cuid())
  adminId      String
  audienceJson String   @default("{}")
  type         String // PushNotificationType (обычно system | news | marketing)
  title        String
  body         String
  url          String   @default("/")
  totalTargets Int      @default(0)
  sent         Int      @default(0)
  failed       Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// Личный диалог ровно между двумя пользователями. Пара канонически
/// отсортирована (userAId < userBId по строковому сравнению) — это гарантирует
/// один диалог на пару через @@unique. Поля *LastReadAt хранят «прочитано до»
/// для каждой стороны (A/B) — из них считаются непрочитанные и «галочки».
model Conversation {
  id            String   @id @default(cuid())
  userAId       String
  userBId       String
  userA         User     @relation("ConvUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB         User     @relation("ConvUserB", fields: [userBId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  /// Время последнего сообщения — для сортировки списка диалогов.
  lastMessageAt DateTime @default(now())
  /// «Прочитано до» для стороны A / стороны B. Null — ещё не открывала диалог.
  aLastReadAt   DateTime?
  bLastReadAt   DateTime?

  messages DirectMessage[]

  @@unique([userAId, userBId])
  @@index([userAId, lastMessageAt])
  @@index([userBId, lastMessageAt])
}

/// Одно личное сообщение в диалоге.
model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("DmSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  /// Прикреплённое изображение (/api/uploads/dm/...). Null — текстовое сообщение.
  imageUrl       String?
  imageWidth     Int?
  imageHeight    Int?
  /// Голосовое сообщение (/api/uploads/dm-voice/...). Null — не голосовое.
  voiceUrl       String?
  /// Длительность голосового в секундах.
  voiceDurationSec Float?
  /// Амплитудная волна голосового — JSON-массив целых 0..100 (для отрисовки без декода).
  voicePeaksJson String?
  /// Когда получатель впервые прослушал голосовое (для индикатора «прослушано»). Null — нет.
  voicePlayedAt  DateTime?
  /// Видеосообщение («кружок»): готовый mp4 (/api/uploads/dm-video/...). Null — не видео
  /// или ещё транскодируется (тогда videoStatus='processing').
  videoUrl       String?
  /// Постер-кадр (jpg) видеосообщения — первый кадр для бабла.
  videoThumbUrl  String?
  /// Длительность видеосообщения, сек.
  videoDurationSec Float?
  /// Стадия: 'processing' | 'ready' | 'failed'. Null — не видеосообщение.
  videoStatus    String?
  /// Карточка-приглашение в комнату («Watch Party»): id приглашённой комнаты.
  /// Null — обычное сообщение (не приглашение).
  inviteRoomId     String?
  /// Слаг комнаты на момент отправки — для перехода без похода в БД.
  inviteRoomSlug   String?
  /// Снапшот названия комнаты на момент отправки приглашения.
  inviteRoomName   String?
  /// Снапшот «что сейчас играет» на момент отправки. Null — нет видео/неизвестно.
  inviteVideoTitle  String?
  inviteVideoPoster String?
  /// Токен InviteLink, потребляемый при принятии (не отдаётся в DTO).
  inviteToken      String?
  /// 'pending' | 'accepted' | 'declined' | 'expired'. Null — не приглашение.
  inviteStatus     String?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([videoStatus])
  @@index([conversationId, inviteRoomId, inviteStatus])
}

/// Серверная запись о входе (устройство/браузер). JWT пользователя несёт
/// claim `sid` = Session.id; удаление строки = разлогин этого устройства.
model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model Room {
  id              String    @id @default(cuid())
  slug            String    @unique
  name            String
  isPrivate       Boolean   @default(false)
  passwordHash    String?
  maxParticipants Int       @default(20)
  allowGuests     Boolean   @default(true)
  hostOnlyControl Boolean   @default(false)

  ownerId         String
  owner           User      @relation("RoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  videoUrl          String?
  videoPositionSec  Float    @default(0)
  videoStatus       String   @default("paused")
  videoUpdatedAt    DateTime @default(now())
  /// Frozen snapshot of ResolvedMedia for the current videoUrl. Stored as
  /// JSON-encoded string so the runtime can boot cold without re-resolving.
  /// Null when no video is set or for pre-resolver rooms.
  videoResolvedJson String?
  /// JSON-encoded PlaylistItem[] — очередь плейлиста, чтобы она переживала
  /// выход всех участников и холодный старт рантайма (не сбрасывалась в пустую).
  playlistJson      String   @default("[]")

  messages    Message[]
  inviteLinks InviteLink[]
  memberships Membership[]

  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([isPrivate])
}

model Membership {
  id              String   @id @default(cuid())
  roomId          String
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String   // 'admin' | 'member' — owner is implied by Room.ownerId
  permissionsJson String   @default("{}") // partial RoomPermissions; empty = default member
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, roomId])
  @@index([roomId])
}

model Message {
  id              String   @id @default(cuid())
  roomId          String
  room            Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName       String?
  guestAvatarSeed String?
  kind            String   @default("user")
  body            String
  createdAt       DateTime @default(now())

  @@index([roomId, createdAt])
}

model InviteLink {
  id        String    @id @default(cuid())
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  token     String    @unique
  maxUses   Int?
  uses      Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([roomId])
}

/// Cache of resolved media URLs. Keyed by the raw user-supplied URL.
/// Reused across rooms — popular YouTube/etc. links resolve once globally.
model ResolvedMedia {
  sourceUrl   String    @id
  kind        String
  mediaUrl    String
  /// Companion audio-only URL for kind='dual' (YouTube HD split). Без неё
  /// кэш-хит на dual-видео терял звук и плеер падал «отсутствует audioUrl».
  audioUrl    String?
  mime        String?
  title       String?
  durationSec Float?
  poster      String?
  /// Raw resolver dump (e.g. yt-dlp --dump-json output) for debugging.
  rawJson     String
  resolvedAt  DateTime
  /// Null = never expires (direct mp4, magnet, etc.).
  expiresAt   DateTime?

  @@index([expiresAt])
}
