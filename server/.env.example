DATABASE_URL=postgresql://vellin:vellin@localhost:5432/vellin
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars-please
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
WS_TICKET_TTL_SEC=60
# Optional. JSON-encoded RTCIceServer[] appended to the default Google STUN.
# Add a TURN server here for clients behind symmetric NAT.
# Example: ICE_SERVERS=[{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]
ICE_SERVERS=

# Email главного администратора. Пользователь с этим email при логине получит
# isAdmin=true и доступ к админ-панели /admin (REST: /api/admin/*).
# Без значения админ-панель никому недоступна.
ADMIN_EMAIL=
