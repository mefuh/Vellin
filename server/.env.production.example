# Шаблон production-окружения сервера Vellin.
# Скопировать в .env на проде и заполнить.

DATABASE_URL=postgresql://vellin:CHANGE_ME@postgres:5432/vellin
JWT_SECRET=PUT_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS_HERE
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
CORS_ORIGIN=https://vellin.ru

# WS-ticket TTL (секунды) — короткий по умолчанию, для гостей хватает.
WS_TICKET_TTL_SEC=60

# Опциональный TURN-сервер для NAT (JSON-массив RTCIceServer).
# ICE_SERVERS=[{"urls":"turn:turn.example.com:3478","username":"u","credential":"p"}]
ICE_SERVERS=

# Главный администратор сервиса. Email пользователя, который получит isAdmin=true
# при логине и доступ к /admin. Без значения админ-панель недоступна.
ADMIN_EMAIL=
