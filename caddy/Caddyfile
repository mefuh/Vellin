# vellin.ru — production reverse proxy + SPA host
#
# Caddy auto-provisions Let's Encrypt certificates for both apex and www on
# first request (ports 80/443 must reach this container from the public IP).
# www.vellin.ru is permanently redirected to the apex.

{$DOMAIN:vellin.ru} {
	encode gzip zstd

	# All routing goes through `handle` blocks so the matchers are explicit
	# and mutually exclusive. The WebSocket endpoint must be its own handle —
	# previously `reverse_proxy @ws` sat outside any handle and the catch-all
	# `handle {}` swallowed /ws into the SPA fallback (200 text/html instead
	# of a 101 Upgrade).
	handle /ws {
		reverse_proxy server:3001
	}

	handle /api/* {
		reverse_proxy server:3001
	}

	# Single-page app fallback. Anything that isn't /api or /ws falls through
	# to the prebuilt client assets baked into the Caddy image.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	# Reduce log noise in production — only HTTP errors, structured JSON.
	log {
		output stdout
		format json
		level INFO
	}
}

www.{$DOMAIN:vellin.ru} {
	redir https://{$DOMAIN:vellin.ru}{uri} permanent
}
