# vellin.ru — production reverse proxy + SPA host
#
# Caddy auto-provisions Let's Encrypt certificates for both apex and www on
# first request (ports 80/443 must reach this container from the public IP).
# www.vellin.ru is permanently redirected to the apex.

{$DOMAIN:vellin.ru} {
	encode gzip zstd

	# All routing goes through `handle` blocks so the matchers are explicit
	# and mutually exclusive. The WebSocket endpoints must be their own handle —
	# previously `reverse_proxy @ws` sat outside any handle and the catch-all
	# `handle {}` swallowed /ws into the SPA fallback (200 text/html instead
	# of a 101 Upgrade).
	#
	# `/ws`     — комнатный сокет (видео/чат/звонок).
	# `/ws/*`   — пользовательский realtime-канал `/ws/user` (друзья,
	#             уведомления, presence). `handle /ws` матчит ТОЛЬКО точный
	#             путь, поэтому используем именованный matcher с двумя путями
	#             (`handle` принимает лишь один токен-matcher, перечислять пути
	#             прямо в нём нельзя).
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy server:3001
	}

	handle /api/* {
		reverse_proxy server:3001
	}

	# Single-page app fallback. Anything that isn't /api or /ws falls through
	# to the prebuilt client assets baked into the Caddy image.
	handle {
		root * /srv

		# Хэшированные ассеты (имя файла меняется при изменении контента) —
		# кэшируем максимально долго и помечаем immutable.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# Оболочка (index.html, манифест, иконки) и SPA-fallback — без долгого
		# кэша: всегда ревалидируем по ETag. Иначе iOS в режиме web-app залипает
		# на старом index.html (он ссылается на старый JS) и обновления не видны.
		@shell not path /assets/*
		header @shell Cache-Control "no-cache"

		# Корректный MIME для манифеста — иначе iOS 16.4+ может не прочитать
		# scope/display из манифеста и выкидывать переходы в Safari.
		@manifest path /manifest.webmanifest
		header @manifest Content-Type "application/manifest+json"

		try_files {path} /index.html
		file_server
	}

	# Reduce log noise in production — only HTTP errors, structured JSON.
	log {
		output stdout
		format json
		level INFO
	}
}

www.{$DOMAIN:vellin.ru} {
	redir https://{$DOMAIN:vellin.ru}{uri} permanent
}
